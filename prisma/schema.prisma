generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
  SCHOOLADMIN
  TEACHER
}

enum ScheduleType {
  TERM
  HOLIDAY
}

enum PrintJobStatus {
  CREATED
  PRINTING
  PAUSED
  COMPLETED
  FAILED
}

enum PupilStatus {
  REGISTERED
  UNREGISTERED
}

enum AbsenceScope {
  PUPIL
  CLASSROOM
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  role           UserRole  @default(USER)
  hashedPassword String?

  printJobs PrintJob[] @relation("UserPrintJobs")

  schoolId String? @map("school_id")
  school   School? @relation("UserToSchool", fields: [schoolId], references: [id])

  teachingClassrooms Classroom[] @relation("TeachersClassrooms")
  pupils             Pupil[]     @relation("ParentChildren")

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model School {
  id   String @id @default(cuid())
  name String

  users      User[]      @relation("UserToSchool")
  classrooms Classroom[]
  schedules  Schedule[]
  absences   Absence[]

  menuLinks MenuSchool[]
}

model Classroom {
  id   String @id @default(cuid())
  name String

  school   School @relation(fields: [schoolId], references: [id])
  schoolId String

  totalPupils Int @default(0)

  pupils   Pupil[]   @relation("ClassStudents")
  teachers User[]    @relation("TeachersClassrooms")
  absences Absence[] @relation("AbsenceClassroom")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
}

model Pupil {
  id     String      @id @default(cuid())
  name   String
  status PupilStatus @default(UNREGISTERED)

  parentId String?
  parent   User?   @relation("ParentChildren", fields: [parentId], references: [id])

  classroomId String
  classroom   Classroom @relation("ClassStudents", fields: [classroomId], references: [id])

  studentName String?
  allergies   String[] @default([])

  orders       LunchOrder[]
  weekPatterns PupilMealWeekPattern[]
  absences     Absence[]              @relation("AbsencePupil")

  menuId String?
  menu   Menu?   @relation(fields: [menuId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([menuId])
  @@index([parentId])
  @@index([classroomId])
  @@index([classroomId, name])
}

model MealGroup {
  id                  String                @id @default(cuid())
  name                String
  maxSelections       Int
  active              Boolean               @default(true)
  choices             MealChoice[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  MenuMealGroup       MenuMealGroup[]
  MealOptionMealGroup MealOptionMealGroup[]
}

model MealChoice {
  id       String  @id @default(cuid())
  name     String
  imageUrl String? @db.Text

  group   MealGroup @relation(fields: [groupId], references: [id])
  groupId String

  allergens   Allergen[]
  ingredients String[]   @default([])

  availStart DateTime?
  availEnd   DateTime?

  active       Boolean @default(false)
  extraSticker Boolean @default(false)

  caloriesKcal Int?
  proteinG     Float?
  carbsG       Float?
  sugarsG      Float?
  fatG         Float?
  saturatesG   Float?
  fibreG       Float?
  saltG        Float?

  orderItems       OrderItem[]
  menuLinks        MenuMealChoice[]
  weekPatternItems PupilMealWeekPatternItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([groupId, active])
  @@index([availStart, availEnd])
}

model Allergen {
  id   String @id @default(cuid())
  name String @unique

  mealChoices MealChoice[]
  mealOptions MealOption[]
}

model Menu {
  id     String  @id @default(cuid())
  name   String
  active Boolean @default(false)

  schoolLinks MenuSchool[]
  pupils      Pupil[]
  groupLinks  MenuMealGroup[]
  choiceLinks MenuMealChoice[]

  mealOptions MealOption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name])
}

model MealOption {
  id     String @id @default(cuid())
  name   String
  menuId String
  menu   Menu   @relation(fields: [menuId], references: [id])

  active       Boolean @default(true)
  imageUrl     String? @db.Text
  stickerCount Int     @default(1)

  availStart DateTime?
  availEnd   DateTime?

  caloriesKcal Int?
  proteinG     Float?
  carbsG       Float?
  sugarsG      Float?
  fatG         Float?
  saturatesG   Float?
  fibreG       Float?
  saltG        Float?

  allergens           Allergen[]
  MealOptionMealGroup MealOptionMealGroup[]
  lunchOrders         LunchOrder[]
  weekPatterns        PupilMealWeekPattern[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([menuId, active])
  @@index([availStart, availEnd])
}

model MenuSchool {
  id       String @id @default(cuid())
  menuId   String
  schoolId String

  menu   Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([menuId, schoolId])
  @@index([menuId])
  @@index([schoolId])
}

model MenuMealGroup {
  id      String @id @default(cuid())
  menuId  String
  groupId String

  maxSelectionsOverride Int?

  menu  Menu      @relation(fields: [menuId], references: [id], onDelete: Cascade)
  group MealGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([menuId, groupId])
  @@index([menuId])
  @@index([groupId])
}

model MenuMealChoice {
  id       String @id @default(cuid())
  menuId   String
  choiceId String

  menu   Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  choice MealChoice @relation(fields: [choiceId], references: [id], onDelete: Cascade)

  @@unique([menuId, choiceId])
  @@index([menuId])
  @@index([choiceId])
}

model MealOptionMealGroup {
  id           String @id @default(cuid())
  mealOptionId String
  groupId      String

  mealOption MealOption @relation(fields: [mealOptionId], references: [id], onDelete: Cascade)
  group      MealGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([mealOptionId, groupId])
  @@index([mealOptionId])
  @@index([groupId])
}

model LunchOrder {
  id      String   @id @default(cuid())
  date    DateTime
  pupilId String
  pupil   Pupil    @relation(fields: [pupilId], references: [id])

  mealOptionId String
  mealOption   MealOption @relation(fields: [mealOptionId], references: [id])

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pupilId, date])
  @@index([pupilId, date])
  @@index([mealOptionId])
}

model OrderItem {
  id      String     @id @default(cuid())
  orderId String
  order   LunchOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  choiceId String
  choice   MealChoice @relation(fields: [choiceId], references: [id])

  selectedIngredients String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([choiceId])
}

model PupilMealWeekPattern {
  id      String @id @default(cuid())
  pupilId String
  pupil   Pupil  @relation(fields: [pupilId], references: [id], onDelete: Cascade)

  weekday Int // 1=Mon ... 5=Fri

  mealOptionId String
  mealOption   MealOption @relation(fields: [mealOptionId], references: [id])

  items PupilMealWeekPatternItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pupilId, weekday])
  @@index([pupilId, weekday])
  @@index([mealOptionId])
}

model PupilMealWeekPatternItem {
  id        String               @id @default(cuid())
  patternId String
  pattern   PupilMealWeekPattern @relation(fields: [patternId], references: [id], onDelete: Cascade)

  choiceId String
  choice   MealChoice @relation(fields: [choiceId], references: [id])

  selectedIngredients String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patternId])
  @@index([choiceId])
}

model Schedule {
  id        String       @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  type      ScheduleType

  school   School @relation(fields: [schoolId], references: [id])
  schoolId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, schoolId])
}

model Absence {
  id    String       @id @default(cuid())
  name  String
  scope AbsenceScope

  startDate DateTime
  endDate   DateTime

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  classroomId String?
  classroom   Classroom? @relation("AbsenceClassroom", fields: [classroomId], references: [id], onDelete: Cascade)

  pupilId String?
  pupil   Pupil?  @relation("AbsencePupil", fields: [pupilId], references: [id], onDelete: Cascade)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, startDate])
  @@index([classroomId, startDate])
  @@index([pupilId, startDate])
}

model PrintJob {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  createdById String?
  createdBy   User?   @relation("UserPrintJobs", fields: [createdById], references: [id], onDelete: SetNull)

  date        DateTime
  schoolId    String?
  classroomId String?

  status      PrintJobStatus @default(CREATED)
  nextSeq     Int            @default(1)
  totalLabels Int            @default(0)

  items PrintJobItem[]

  @@index([date])
  @@index([status])
  @@index([createdById])
}

model PrintJobItem {
  id String @id @default(cuid())

  jobId String
  job   PrintJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  schoolName String
  choiceId   String?
  allergens  String[] @default([])

  seq Int

  pupilId   String
  pupilName String
  classroom String
  mealType  String
  choice    String
  extras    String[] @default([])

  printedAt  DateTime?
  printError String?

  @@unique([jobId, seq])
  @@index([jobId, seq])
  @@index([pupilId])
}
