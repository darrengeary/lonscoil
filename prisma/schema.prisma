generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

/// ------------------------------------------------------
/// Enums
/// ------------------------------------------------------

enum UserRole {
  ADMIN
  USER
  SCHOOLADMIN
  TEACHER
}

enum ScheduleType {
  TERM
  HOLIDAY
}

enum PrintJobStatus {
  CREATED
  PRINTING
  PAUSED
  COMPLETED
  FAILED
}

enum PupilStatus {
  REGISTERED
  UNREGISTERED
}

enum AbsenceScope {
  PUPIL
  CLASSROOM
}

/// ------------------------------------------------------
/// Auth Models
/// ------------------------------------------------------

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// ------------------------------------------------------
/// Users
/// ------------------------------------------------------

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  role           UserRole  @default(USER)
  hashedPassword String?

  printJobs PrintJob[] @relation("UserPrintJobs")

  // SCHOOLADMIN: Assigned to a school
  schoolId String? @map("school_id")
  school   School? @relation("UserToSchool", fields: [schoolId], references: [id])

  // TEACHER: Many-to-many with classrooms
  teachingClassrooms Classroom[] @relation("TeachersClassrooms")

  // PARENT: Linked to pupils (children)
  pupils Pupil[] @relation("ParentChildren")

  // Auth relations
  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
}

/// ------------------------------------------------------
/// Schools
/// ------------------------------------------------------

model School {
  id   String @id @default(cuid())
  name String

  users      User[] @relation("UserToSchool")
  classrooms Classroom[]
  schedules  Schedule[]
  absences   Absence[]

  menuLinks MenuSchool[]
}

/// ------------------------------------------------------
/// Classrooms & Pupils
/// ------------------------------------------------------

model Classroom {
  id   String @id @default(cuid())
  name String

  school   School @relation(fields: [schoolId], references: [id])
  schoolId String

  totalPupils Int @default(0)

  pupils   Pupil[]   @relation("ClassStudents")
  teachers User[]    @relation("TeachersClassrooms")
  absences Absence[] @relation("AbsenceClassroom")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
}

model Pupil {
  id     String      @id @default(cuid())
  name   String
  status PupilStatus @default(UNREGISTERED)

  parentId String?
  parent   User? @relation("ParentChildren", fields: [parentId], references: [id])

  classroomId String
  classroom   Classroom @relation("ClassStudents", fields: [classroomId], references: [id])

  // Parent-entered registration details
  studentName String?
  allergies   String[] @default([])

  orders   LunchOrder[]
  absences Absence[] @relation("AbsencePupil")

  menuId String?
  menu   Menu? @relation(fields: [menuId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([menuId])
  @@index([parentId])
  @@index([classroomId])
}

/// ------------------------------------------------------
/// Meal Selection
/// ------------------------------------------------------

model MealGroup {
  id            String @id @default(cuid())
  name          String
  maxSelections Int    @default(1)

  choices   MealChoice[]
  menuLinks MenuMealGroup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MealChoice {
  id       String  @id @default(cuid())
  name     String
  imageUrl String? @db.Text

  group   MealGroup @relation(fields: [groupId], references: [id])
  groupId String

  allergens   Allergen[]
  ingredients String[] @default([])

  availStart DateTime?
  availEnd   DateTime?

  active Boolean @default(true)

  caloriesKcal Int?
  proteinG     Float?
  carbsG       Float?
  sugarsG      Float?
  fatG         Float?
  saturatesG   Float?
  fibreG       Float?
  saltG        Float?

  orderItems OrderItem[]

  menuLinks MenuMealChoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Allergen {
  id   String @id @default(cuid())
  name String @unique

  mealChoices MealChoice[]
}

/// ------------------------------------------------------
/// Menus
/// ------------------------------------------------------

model Menu {
  id     String @id @default(cuid())
  name   String
  active Boolean @default(true)

  schoolLinks MenuSchool[]
  pupils      Pupil[]
  groupLinks  MenuMealGroup[]
  choiceLinks MenuMealChoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name])
}

model MenuSchool {
  id       String @id @default(cuid())
  menuId   String
  schoolId String

  menu   Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([menuId, schoolId])
  @@index([menuId])
  @@index([schoolId])
}

model MenuMealGroup {
  id      String @id @default(cuid())
  menuId  String
  groupId String

  maxSelectionsOverride Int?

  menu  Menu      @relation(fields: [menuId], references: [id], onDelete: Cascade)
  group MealGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([menuId, groupId])
  @@index([menuId])
  @@index([groupId])
}

model MenuMealChoice {
  id       String @id @default(cuid())
  menuId   String
  choiceId String

  menu   Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  choice MealChoice @relation(fields: [choiceId], references: [id], onDelete: Cascade)

  @@unique([menuId, choiceId])
  @@index([menuId])
  @@index([choiceId])
}

/// ------------------------------------------------------
/// Orders
/// ------------------------------------------------------

model LunchOrder {
  id      String   @id @default(cuid())
  date    DateTime
  pupilId String
  pupil   Pupil    @relation(fields: [pupilId], references: [id])

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pupilId, date])
}

model OrderItem {
  id      String     @id @default(cuid())
  orderId String
  order   LunchOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  choiceId String
  choice   MealChoice @relation(fields: [choiceId], references: [id])

  selectedIngredients String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// ------------------------------------------------------
/// Schedule
/// ------------------------------------------------------

model Schedule {
  id        String       @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  type      ScheduleType

  school   School @relation(fields: [schoolId], references: [id])
  schoolId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, schoolId])
}

/// ------------------------------------------------------
/// Absences
/// ------------------------------------------------------

model Absence {
  id    String       @id @default(cuid())
  name  String
  scope AbsenceScope

  startDate DateTime
  endDate   DateTime

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  classroomId String?
  classroom   Classroom? @relation("AbsenceClassroom", fields: [classroomId], references: [id], onDelete: Cascade)

  pupilId String?
  pupil   Pupil? @relation("AbsencePupil", fields: [pupilId], references: [id], onDelete: Cascade)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, startDate])
  @@index([classroomId, startDate])
  @@index([pupilId, startDate])
}

/// ------------------------------------------------------
/// Print Jobs
/// ------------------------------------------------------

model PrintJob {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  createdById String?
  createdBy   User? @relation("UserPrintJobs", fields: [createdById], references: [id], onDelete: SetNull)

  date        DateTime
  schoolId    String?
  classroomId String?

  status      PrintJobStatus @default(CREATED)
  nextSeq     Int            @default(1)
  totalLabels Int            @default(0)

  items PrintJobItem[]

  @@index([date])
  @@index([status])
  @@index([createdById])
}

model PrintJobItem {
  id String @id @default(cuid())

  jobId String
  job   PrintJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  schoolName String
  choiceId   String?
  allergens  String[] @default([])

  seq Int

  pupilId   String
  pupilName String
  classroom String
  mealType  String
  choice    String
  extras    String[] @default([])

  printedAt  DateTime?
  printError String?

  @@unique([jobId, seq])
  @@index([jobId, seq])
  @@index([pupilId])
}